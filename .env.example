# ============================================
# 🧠 Watch Later Agent — Environment Variables
# ============================================
# Copie este arquivo para .env e preencha os valores.

# --- Discord ---
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_GUILD_ID=your_discord_server_id

# --- LLM Provider ---
# Opções: "gemini" | "openai"
LLM_PROVIDER=gemini

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key

# --- OpenAI (fallback) ---
OPENAI_API_KEY=your_openai_api_key

# --- YouTube / Browser ---
# Caminho para o executável do Chrome/Brave (opcional, Puppeteer usa o bundled por padrão)
# Ex Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# Ex Linux:   /usr/bin/google-chrome
CHROME_EXECUTABLE_PATH=

# Browser para extração de cookies do yt-dlp: chrome | brave | firefox | edge
COOKIES_BROWSER=chrome

# --- Database ---
DATABASE_URL="file:./data/watchlater.db"

# --- WhatsApp ---
# Envio de resumos para grupo no WhatsApp (opcional)
WHATSAPP_ENABLED=false
WHATSAPP_GROUP_NAME="Segundo Cérebro"
# always: notifica cada vídeo | digest: notifica 1x por dia
WHATSAPP_MODE=always

# --- App ---
# Nível de log: debug | info | warn | error
LOG_LEVEL=info

# Idioma preferido para resumos: pt-BR | en | auto
SUMMARY_LANGUAGE=pt-BR
