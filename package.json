{
  "name": "discord-watchlater",
  "version": "1.0.0",
  "description": "🧠 Watch Later Agent — Segundo Cérebro. Monitora sua playlist do YouTube, sintetiza conhecimento via LLM e entrega via Discord.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "tsx src/services/youtube/auth-setup.ts",
    "deploy-commands": "tsx src/bot/deploy-commands.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^6.9.0",
    "@whiskeysockets/baileys": "^6.7.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.0",
    "openai": "^4.80.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "puppeteer": "^24.8.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "qrcode-terminal": "^0.12.0",
    "youtube-transcript": "^1.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/qrcode-terminal": "^0.12.2",
    "prisma": "^6.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
